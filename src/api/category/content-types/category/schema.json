{
  "kind": "collectionType",
  "collectionName": "categories",
  "info": {
    "singularName": "category",
    "pluralName": "categories",
    "displayName": "Category",
    "description": "Genealogy document categories"
  },
  "options": {
    "draftAndPublish": false
  },
  "pluginOptions": {},
  "attributes": {
    "categoryId": {
      "type": "string",
      "required": true,
      "unique": true
    },
    "title": {
      "type": "string",
      "required": true
    },
    "image": {
      "type": "string"
    },
    "href": {
      "type": "string"
    },
    "order": {
      "type": "integer",
      "required": true,
      "default": 0
    },
    "documents": {
      "type": "component",
      "repeatable": true,
      "component": "shared.document"
    }
  }
}
